# ================= SESSION =================
SESSIONS = {}

# ================= PASSWORD HASH =================
def hash_password(password, salt=None):
    if salt is None:
        salt = os.urandom(16)
    pwd_hash = hashlib.scrypt(password.encode(), salt=salt, n=2**14, r=8, p=1, dklen=64)
    return salt, pwd_hash

def verify_password(password, salt, stored):
    computed = hashlib.scrypt(password.encode(), salt=salt, n=2**14, r=8, p=1, dklen=64)
    return secrets.compare_digest(computed, stored)

# ================= COOKIES =================
def parse_cookies(header):
    cookies = {}
    if header:
        for part in header.split(";"):
            if "=" in part:
                k, v = part.strip().split("=", 1)
                cookies[k] = v
    return cookies

def get_user(handler):
    cookies = parse_cookies(handler.headers.get("Cookie"))
    sid = cookies.get("session_id")
    return SESSIONS.get(sid, {}).get("username") if sid else None

def create_session(handler, username):
    sid = secrets.token_urlsafe(24)
    SESSIONS[sid] = {"username": username}
    handler.send_header("Set-Cookie", f"session_id={sid}; Path=/; HttpOnly")

def destroy_session(handler):
    cookies = parse_cookies(handler.headers.get("Cookie"))
    sid = cookies.get("session_id")
    if sid in SESSIONS:
        del SESSIONS[sid]

# ================= DB =================
def create_user(username, password):
    salt, pwd_hash = hash_password(password)

    conn = get_connection()
    cur = conn.cursor()

    cur.execute("""
        INSERT INTO users (username, salt, password_hash, created)
        VALUES (:1, :2, :3, :4)
    """, (username, salt, pwd_hash, time.time()))

    conn.commit()
    cur.close()
    conn.close()

def get_user_db(username):
    conn = get_connection()
    cur = conn.cursor()

    cur.execute("""
        SELECT username, salt, password_hash
        FROM users
        WHERE LOWER(username) = :1
    """, [username.lower()])

    row = cur.fetchone()
    cur.close()
    conn.close()
    return row

