# ================= SERVER =================
class Handler(http.server.BaseHTTPRequestHandler):

    def do_GET(self):
        user = get_user(self)

        if self.path == "/":
            self.respond(page("Login", """
                <div class="card">
                    <form method="post" action="/login">
                        Username:<br><input name="username"><br>
                        Password:<br><input type="password" name="password"><br>
                        <button>Login</button>
                    </form>

                    <br>
                    <a href="/register">
                        <button type="button">Create Account</button>
                    </a>
                </div>
            """))
            return

        if self.path == "/register":
            self.respond(page("Register", """
                <div class="card">
                    <form method="post" action="/register">
                        Username:<br><input name="username"><br>
                        Password:<br><input type="password" name="password"><br>
                        Confirm:<br><input type="password" name="password2"><br>
                        <button>Create Account</button>
                    </form>
                </div>
            """))
            return

        if self.path == "/dashboard":
            if not user:
                self.redirect("/")
                return

            self.respond(page("Dashboard", f"""
                <div class="card">
                    Welcome <b>{html.escape(user)}</b>
                </div>
            """, user))
            return

        if self.path == "/logout":
            destroy_session(self)
            self.redirect("/")
            return

        if self.path == "/incidents":
            if not user:
                self.redirect("/")
                return

            conn = get_connection()
            cur = conn.cursor()
            cur.execute("SELECT character, severity FROM incidents WHERE username=:1", [user])

            items = ""
            for c, s in cur.fetchall():
                items += f"<div class='card'>🚩 {html.escape(c)} — Severity {s}</div>"

            cur.close()
            conn.close()

            self.respond(page("Incidents", items, user))
            return

        if self.path == "/incidents/new":
            if not user:
                self.redirect("/")
                return

            self.respond(page("Add Incident", """
                <div class="card">
                    <form method="post" action="/incidents/new">
                        Character:<br><input name="character"><br>
                        Severity (1-5):<br><input name="severity"><br>
                        Notes:<br><textarea name="notes"></textarea><br>
                        Show:<br><input name="show"><br>
                        <button>Save</button>
                    </form>
                </div>
            """, user))
            return

    def do_POST(self):
        length = int(self.headers.get("Content-Length", 0))
        data = urllib.parse.parse_qs(self.rfile.read(length).decode())

        # REGISTER
        if self.path == "/register":
            u = data.get("username", [""])[0]
            p = data.get("password", [""])[0]
            p2 = data.get("password2", [""])[0]

            if p != p2:
                self.respond(page("Register", "Passwords do not match"))
                return

            try:
                create_user(u, p)
            except Exception as e:
                self.respond(page("Register", f"Error: {e}"))
                return

            self.redirect("/")
            return

        # LOGIN
        if self.path == "/login":
            u = data.get("username", [""])[0]
            p = data.get("password", [""])[0]

            row = get_user_db(u)

            if row:
                db_user, salt, pwd = row

                if isinstance(salt, memoryview):
                    salt = salt.tobytes()
                if isinstance(pwd, memoryview):
                    pwd = pwd.tobytes()

                if verify_password(p, salt, pwd):
                    self.send_response(302)
                    self.send_header("Location", "/dashboard")
                    create_session(self, db_user)
                    self.end_headers()
                    return

            self.respond(page("Login", "Login failed 🚩"))
            return

        # INCIDENT
        if self.path == "/incidents/new":
            user = get_user(self)
            if not user:
                self.redirect("/")
                return

            conn = get_connection()
            cur = conn.cursor()

            cur.execute("""
                INSERT INTO incidents (username, character, severity, notes, show, ts)
                VALUES (:1, :2, :3, :4, :5, :6)
            """, (
                user,
                data.get("character", [""])[0],
                int(data.get("severity", ["1"])[0]),
                data.get("notes", [""])[0],
                data.get("show", [""])[0],
                time.time()
            ))

            conn.commit()
            cur.close()
            conn.close()

            self.redirect("/incidents")

    def respond(self, html_text):
        self.send_response(200)
        self.send_header("Content-Type", "text/html")
        self.end_headers()
        self.wfile.write(html_text.encode())

    def redirect(self, loc):
        self.send_response(302)
        self.send_header("Location", loc)
        self.end_headers()

# ================= RUN =================
def run():
    with socketserver.TCPServer(("", PORT), Handler) as httpd:
        print("Running on http://localhost:8080")
        httpd.serve_forever()

if __name__ == "__main__":
